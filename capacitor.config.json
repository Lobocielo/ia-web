{
  "appId": "com.lobocielo.nexusai",
  "appName": "Nexus AI",
  "webDir": "out",
  "server": {
    "androidScheme": "https",
    "url": "https://ia-web-mu.vercel.app",
    "cleartext": true,
    "allowNavigation": ["*"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a12",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
